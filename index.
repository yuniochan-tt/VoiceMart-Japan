};

/* =====================================================
   CART STATE
===================================================== */
let cart = {}; // { productId: { product, qty } }

function getCartTotal() {
  return Object.values(cart).reduce((sum, {product, qty}) => sum + product.price * qty, 0);
}
function getCartCount() {
  return Object.values(cart).reduce((sum, {qty}) => sum + qty, 0);
}

/* =====================================================
   CART: Add / Remove / Render
===================================================== */
function addToCart(productId) {
  const product = PRODUCTS.find(p => p.id === productId);
  if (!product) return;
  if (cart[productId]) {
    cart[productId].qty++;
  } else {
    cart[productId] = { product, qty: 1 };
  }
  updateCartUI();
  showToast(`${product.emoji} ${product.name} をカートに追加しました`);
}

function changeQty(productId, delta) {
  if (!cart[productId]) return;
  cart[productId].qty += delta;
  if (cart[productId].qty <= 0) delete cart[productId];
  updateCartUI();
}

function removeFromCart(productId) {
  delete cart[productId];
  updateCartUI();
}

function updateCartUI() {
  const count = getCartCount();
  const total = getCartTotal();

  // Header badge
  document.getElementById('cart-count').textContent = count;
  document.getElementById('cart-open-btn').setAttribute('aria-label', `カートを開く（${count}点）`);

  // Sidebar
  const itemsEl = document.getElementById('cart-items');
  const emptyEl = document.getElementById('cart-empty');
  const totalEl = document.getElementById('cart-total');

  totalEl.textContent = `¥${total.toLocaleString()}`;

  // Clear existing items (keep empty msg)
  const existingItems = itemsEl.querySelectorAll('.cart-item');
  existingItems.forEach(el => el.remove());

  if (count === 0) {
    emptyEl.style.display = 'block';
  } else {
    emptyEl.style.display = 'none';
    Object.values(cart).forEach(({product, qty}) => {
      const item = document.createElement('div');
      item.className = 'cart-item';
      item.setAttribute('role', 'listitem');
      item.innerHTML = `
        <span class="cart-item-emoji" aria-hidden="true">${product.emoji}</span>
        <div class="cart-item-info">
          <div class="cart-item-name">${product.name}</div>
          <div class="cart-item-price">¥${(product.price * qty).toLocaleString()}</div>
          <div class="cart-item-qty">
            <button class="qty-btn" onclick="changeQty(${product.id},-1)"
              aria-label="${product.name}の数量を減らす">－</button>
            <span class="qty-num" aria-label="数量 ${qty}">${qty}</span>
            <button class="qty-btn" onclick="changeQty(${product.id},1)"
              aria-label="${product.name}の数量を増やす">＋</button>
          </div>
        </div>
        <button class="cart-item-del" onclick="removeFromCart(${product.id})"
          aria-label="${product.name}をカートから削除">🗑️</button>
      `;
      itemsEl.appendChild(item);
    });
  }
}

/* =====================================================
   CART: Open / Close
===================================================== */
function openCart() {
  document.getElementById('cart-sidebar').classList.add('open');
  document.getElementById('cart-overlay').classList.add('open');
  document.getElementById('cart-open-btn').setAttribute('aria-expanded', 'true');
  // Focus close button
  setTimeout(() => {
    const closeBtn = document.querySelector('.cart-close');
    if (closeBtn) closeBtn.focus();
  }, 100);
}
function closeCart() {
  document.getElementById('cart-sidebar').classList.remove('open');
  document.getElementById('cart-overlay').classList.remove('open');
  document.getElementById('cart-open-btn').setAttribute('aria-expanded', 'false');
  document.getElementById('cart-open-btn').focus();
}

document.getElementById('cart-open-btn').addEventListener('click', openCart);

/* =====================================================
   PRODUCT GRID: Render
===================================================== */
function renderProducts(products) {
  const grid = document.getElementById('product-grid');
  grid.innerHTML = '';
  products.forEach(p => {
    const card = document.createElement('article');
    card.className = 'product-card';
    card.setAttribute('data-cat', p.category);
    card.setAttribute('data-name', p.name);
    card.setAttribute('aria-label', `${p.name} ${p.category} ¥${p.price.toLocaleString()}`);
    card.innerHTML = `
      <div class="product-img" role="img" aria-label="${p.name}の画像"
        style="font-size:5rem;background:var(--bg-hero);">
        ${p.emoji}
      </div>
      <div class="product-body">
        <div class="product-category">${p.category}</div>
        <h3 class="product-name">${p.name}</h3>
        <p class="product-desc">${p.desc}</p>
        <div class="product-price">¥${p.price.toLocaleString()}<span>（税込）</span></div>
        <button class="add-to-cart-btn" onclick="addToCart(${p.id})"
          aria-label="${p.name}をカートに追加する">
          🛒 カートに追加
        </button>
      </div>
    `;
    grid.appendChild(card);
  });
}

/* =====================================================
   PRODUCT: Filter by category
===================================================== */
let currentCategory = 'all';
let currentSearch   = '';

function filterByCategory(cat, btn) {
  currentCategory = cat;
  // Update tab states
  document.querySelectorAll('.cat-tab').forEach(t => {
    t.classList.remove('active');
    t.setAttribute('aria-selected', 'false');
  });
  btn.classList.add('active');
  btn.setAttribute('aria-selected', 'true');
  applyFilters();
}

function filterProducts(query) {
  currentSearch = query.toLowerCase();
  applyFilters();
}

function applyFilters() {
  const cards = document.querySelectorAll('.product-card');
  let visible = 0;
  cards.forEach(card => {
    const matchCat  = currentCategory === 'all' || card.dataset.cat === currentCategory;
    const matchName = card.dataset.name.toLowerCase().includes(currentSearch);
    const show = matchCat && matchName;
    card.dataset.hidden = !show;
    if (show) visible++;
  });
  // Announce to screen reader
  const liveEl = document.getElementById('product-grid');
  liveEl.setAttribute('aria-label', `商品リスト（${visible}件表示中）`);
}

/* =====================================================
   いつもの注文: Render
===================================================== */
function renderQuickOrder() {
  const grid = document.getElementById('quick-order-grid');
  QUICK_ITEMS.forEach(item => {
    const el = document.createElement('div');
    el.className = 'quick-item';
    el.setAttribute('aria-label', `${item.name}、前回購入：${item.lastBought}、頻度：${item.freq}`);
    el.innerHTML = `
      <div class="quick-item-emoji" aria-hidden="true">${item.emoji}</div>
      <div class="quick-item-name">${item.name}</div>
      <div class="quick-item-info">前回：${item.lastBought} / ${item.freq}</div>
      <button class="reorder-btn" onclick="addToCart(${item.id})"
        aria-label="${item.name}を再注文する">
        🔄 再注文
      </button>
    `;
    grid.appendChild(el);
  });
}

/* =====================================================
   AI CHAT
===================================================== */
let isTyping = false;

function initChat() {
  addBotMessage('こんにちは！😊 やさしい買い物アシスタントです。ご注文のお手伝いをします。「牛乳を注文したい」など、お気軽にお声がけください。');
}

function addBotMessage(text) {
  const messages = document.getElementById('chat-messages');
  const msg = document.createElement('div');
  msg.className = 'msg bot';
  msg.innerHTML = `
    <div class="msg-avatar" aria-hidden="true">🤖</div>
    <div class="msg-bubble">${text}</div>
  `;
  messages.appendChild(msg);
  messages.scrollTop = messages.scrollHeight;
}

function addUserMessage(text) {
  const messages = document.getElementById('chat-messages');
  const msg = document.createElement('div');
  msg.className = 'msg user';
  msg.innerHTML = `
    <div class="msg-avatar" aria-hidden="true">👤</div>
    <div class="msg-bubble">${text}</div>
  `;
  messages.appendChild(msg);
  messages.scrollTop = messages.scrollHeight;
}

function showTyping() {
  const messages = document.getElementById('chat-messages');
  const typing = document.createElement('div');
  typing.className = 'msg bot';
  typing.id = 'typing-indicator';
  typing.innerHTML = `
    <div class="msg-avatar" aria-hidden="true">🤖</div>
    <div class="msg-bubble">
      <div class="typing-indicator" aria-label="入力中">
        <span></span><span></span><span></span>
      </div>
    </div>
  `;
  messages.appendChild(typing);
  messages.scrollTop = messages.scrollHeight;
}

function hideTyping() {
  const el = document.getElementById('typing-indicator');
  if (el) el.remove();
}

function getBotResponse(input) {
  const lower = input.toLowerCase();
  for (const key of Object.keys(BOT_RESPONSES)) {
    if (lower.includes(key)) return BOT_RESPONSES[key];
  }
  return BOT_RESPONSES['default'];
}

function sendChat(text) {
  if (isTyping) return;
  addUserMessage(text);
  isTyping = true;
  showTyping();

  setTimeout(() => {
    hideTyping();
    const resp = getBotResponse(text);
    addBotMessage(resp.text);

    // Auto suggest add to cart
    if (resp.productId) {
      const product = PRODUCTS.find(p => p.id === resp.productId);
      if (product) {
        setTimeout(() => {
          const messages = document.getElementById('chat-messages');
          const msg = document.createElement('div');
          msg.className = 'msg bot';
          msg.innerHTML = `
            <div class="msg-avatar" aria-hidden="true">🤖</div>
            <div class="msg-bubble" style="display:flex;flex-direction:column;gap:8px;">
              <span>カートに追加しますか？</span>
              <button class="add-to-cart-btn" onclick="addToCart(${product.id});sendChat('ありがとう！')"
                aria-label="${product.name}をカートに追加する">
                🛒 ${product.emoji} ${product.name}（¥${product.price.toLocaleString()}）を追加
              </button>
            </div>
          `;
          messages.appendChild(msg);
          messages.scrollTop = messages.scrollHeight;
        }, 400);
      }
    }
    isTyping = false;
  }, 1000 + Math.random() * 500);
}

function sendChatFromInput() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';
  sendChat(text);
}

/* =====================================================
   VOICE SEARCH (Web Speech API)
===================================================== */
let recognition = null;
let isListening = false;

function startVoiceSearch() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRecognition) {
    showToast('⚠️ お使いのブラウザは音声認識に対応していません');
    return;
  }

  if (isListening) {
    recognition.stop();
    return;
  }

  recognition = new SpeechRecognition();
  recognition.lang = 'ja-JP';
  recognition.interimResults = true;
  recognition.continuous = false;

  const micBtn    = document.getElementById('mic-btn');
  const statusEl  = document.getElementById('voice-status');
  const searchEl  = document.getElementById('search-input');

  recognition.onstart = () => {
    isListening = true;
    micBtn.classList.add('listening');
    micBtn.setAttribute('aria-label', '音声入力中...');
    micBtn.setAttribute('aria-pressed', 'true');
    statusEl.textContent = '🎤 聞こえています... 話しかけてください';
    statusEl.classList.add('active');
  };

  recognition.onresult = (e) => {
    const transcript = Array.from(e.results)
      .map(r => r[0].transcript)
      .join('');
    searchEl.value = transcript;
    filterProducts(transcript);
    if (e.results[e.results.length - 1].isFinal) {
      statusEl.textContent = `「${transcript}」で検索中...`;
    }
  };

  recognition.onend = () => {
    isListening = false;
    micBtn.classList.remove('listening');
    micBtn.setAttribute('aria-label', 'マイクで音声検索する');
    micBtn.setAttribute('aria-pressed', 'false');
    statusEl.classList.remove('active');
    const val = searchEl.value;
    statusEl.textContent = val
      ? `「${val}」の検索結果を表示しています`
      : 'マイクボタンを押すと音声入力できます';
  };

  recognition.onerror = (e) => {
    isListening = false;
    micBtn.classList.remove('listening');
    micBtn.setAttribute('aria-pressed', 'false');
    statusEl.classList.remove('active');
    statusEl.textContent = '⚠️ 音声認識エラー。もう一度お試しください';
    showToast('⚠️ マイクへのアクセスを許可してください');
  };

  recognition.start();
}

/* =====================================================
   TEXT TO SPEECH
===================================================== */
let ttsEnabled = false;
let ttsTimeout = null;

function toggleReadAloud() {
  ttsEnabled = !ttsEnabled;
  const btn = document.getElementById('tts-btn');
  btn.classList.toggle('active', ttsEnabled);
  btn.setAttribute('aria-pressed', ttsEnabled);

  if (ttsEnabled) {
    showToast('🔊 読み上げモードON — テキストにカーソルを合わせると読み上げます');
    enableTTSHover();
  } else {
    showToast('🔇 読み上げモードOFF');
    disableTTSHover();
    window.speechSynthesis && window.speechSynthesis.cancel();
  }
}

function enableTTSHover() {
  document.querySelectorAll('p, h1, h2, h3, h4, .product-name, .product-desc, .msg-bubble').forEach(el => {
    el.addEventListener('mouseenter', ttsSpeak);
    el.addEventListener('focus', ttsSpeak);
  });
}

function disableTTSHover() {
  document.querySelectorAll('p, h1, h2, h3, h4, .product-name, .product-desc, .msg-bubble').forEach(el => {
    el.removeEventListener('mouseenter', ttsSpeak);
    el.removeEventListener('focus', ttsSpeak);
    el.classList.remove('tts-active');
  });
}

function ttsSpeak(e) {
  if (!ttsEnabled) return;
  const text = e.target.textContent.trim();
  if (!text) return;
  window.speechSynthesis.cancel();
  const utter = new SpeechSynthesisUtterance(text);
  utter.lang = 'ja-JP';
  utter.rate = 0.9;
  utter.pitch = 1.0;
  e.target.classList.add('tts-active');
  utter.onend = () => e.target.classList.remove('tts-active');
  window.speechSynthesis.speak(utter);
}

/* =====================================================
   ACCESSIBILITY CONTROLS
===================================================== */
let fontLevel = 0; // 0=default, 1=large, 2=xlarge

function changeFontSize(delta) {
  fontLevel = Math.max(0, Math.min(2, fontLevel + delta));
  document.body.classList.remove('large-font', 'xlarge-font');
  if (fontLevel === 1) document.body.classList.add('large-font');
  if (fontLevel === 2) document.body.classList.add('xlarge-font');

  const labels = ['標準', '大', '特大'];
  showToast(`🔠 文字サイズ：${labels[fontLevel]}`);
}

function toggleDarkMode() {
  const body   = document.body;
  const btn    = document.getElementById('dark-mode-btn');
  const isDark = body.classList.toggle('dark-mode');
  btn.classList.toggle('active', isDark);
  btn.setAttribute('aria-pressed', isDark);
  // Remove contrast if dark activated
  if (isDark && body.classList.contains('high-contrast')) {
    body.classList.remove('high-contrast');
    document.getElementById('contrast-btn').classList.remove('active');
    document.getElementById('contrast-btn').setAttribute('aria-pressed', 'false');
  }
  showToast(isDark ? '🌙 ダークモードON' : '☀️ ダークモードOFF');
}

function toggleContrast() {
  const body   = document.body;
  const btn    = document.getElementById('contrast-btn');
  const isHC   = body.classList.toggle('high-contrast');
  btn.classList.toggle('active', isHC);
  btn.setAttribute('aria-pressed', isHC);
  // Remove dark if contrast activated
  if (isHC && body.classList.contains('dark-mode')) {
    body.classList.remove('dark-mode');
    document.getElementById('dark-mode-btn').classList.remove('active');
    document.getElementById('dark-mode-btn').setAttribute('aria-pressed', 'false');
  }
  showToast(isHC ? '◑ ハイコントラストON' : '◑ ハイコントラストOFF');
}

/* =====================================================
   MOBILE NAV
===================================================== */
document.getElementById('hamburger-btn').addEventListener('click', () => {
  const nav = document.getElementById('mobile-nav');
  nav.classList.add('open');
  document.getElementById('hamburger-btn').setAttribute('aria-expanded', 'true');
  document.getElementById('mobile-nav-close').focus();
});

document.getElementById('mobile-nav-close').addEventListener('click', closeMobileNav);
document.getElementById('mobile-nav').addEventListener('click', (e) => {
  if (e.target === e.currentTarget) closeMobileNav();
});

function closeMobileNav() {
  document.getElementById('mobile-nav').classList.remove('open');
  document.getElementById('hamburger-btn').setAttribute('aria-expanded', 'false');
  document.getElementById('hamburger-btn').focus();
}

// Keyboard trap in mobile nav
document.getElementById('mobile-nav').addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeMobileNav();
});

/* =====================================================
   CHECKOUT
===================================================== */
function checkout() {
  if (getCartCount() === 0) {
    showToast('⚠️ カートが空です');
    return;
  }
  const total = getCartTotal().toLocaleString();
  closeCart();
  showToast(`✅ ご注文ありがとうございます！合計：¥${total}（デモ）`);
  cart = {};
  updateCartUI();
}

/* =====================================================
   EMERGENCY BUTTON
===================================================== */
function triggerEmergency() {
  // Speak emergency message
  if (window.speechSynthesis) {
    const utter = new SpeechSynthesisUtterance('緊急サポートにつなぎます。少々お待ちください。');
    utter.lang = 'ja-JP';
    window.speechSynthesis.speak(utter);
  }
  showToast('🆘 緊急サポートに接続中... 担当者がまもなく対応します');
}

/* =====================================================
   TOAST
===================================================== */
let toastTimer = null;

function showToast(msg) {
  const toast   = document.getElementById('toast');
  const msgEl   = document.getElementById('toast-msg');
  const iconEl  = document.getElementById('toast-icon');

  msgEl.textContent = msg.replace(/^[^\s]+\s/, '');
  // Use the emoji prefix as icon
  const match = msg.match(/^([^\s]{1,3})\s/);
  iconEl.textContent = match ? match[1] : '✅';

  toast.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
}

/* =====================================================
   KEYBOARD NAVIGATION
===================================================== */
document.addEventListener('keydown', (e) => {
  // Escape closes cart or mobile nav
  if (e.key === 'Escape') {
    if (document.getElementById('cart-sidebar').classList.contains('open')) {
      closeCart();
    }
    if (document.getElementById('mobile-nav').classList.contains('open')) {
      closeMobileNav();
    }
  }
  // Alt+C opens cart
  if (e.altKey && e.key === 'c') {
    e.preventDefault();
    openCart();
  }
  // Alt+M opens mobile menu
  if (e.altKey && e.key === 'm') {
    e.preventDefault();
    document.getElementById('hamburger-btn').click();
  }
});

/* =====================================================
   INIT
===================================================== */
document.addEventListener('DOMContentLoaded', () => {
  renderProducts(PRODUCTS);
  renderQuickOrder();
  initChat();
  updateCartUI();

  // Announce page load to screen readers
  const liveRegion = document.createElement('div');
  liveRegion.setAttribute('aria-live', 'polite');
  liveRegion.setAttribute('aria-atomic', 'true');
  liveRegion.style.cssText = 'position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;';
  document.body.appendChild(liveRegion);
  setTimeout(() => {
    liveRegion.textContent = 'やさしい買い物のページが読み込まれました。';
  }, 500);
});
</script>

